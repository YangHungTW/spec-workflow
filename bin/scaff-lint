#!/usr/bin/env bash
# =============================================================================
# scaff-lint — CJK guardrail scanner
# =============================================================================
#
# USAGE
#   bin/scaff-lint <subcommand> [paths...]
#   bin/scaff-lint --help
#
# SUBCOMMANDS
#   scan-staged         Scan files staged for commit (reads git diff --cached).
#                       Default subcommand invoked by the pre-commit hook.
#
#   scan-paths <path>   Scan one or more on-disk paths directly.
#               ...
#
# OPTIONS
#   --help, -h          Print this message and exit 0.
#
# OUTPUT CONTRACT
#   stdout (one line per path, parseable by CI/audit scripts):
#     ok:<path>
#     cjk-hit:<path>:<line>:<col>:U+<hex>
#     allowlisted:<path>:<reason>
#     binary-skip:<path>
#
#   stderr: summary and error messages only.
#
# EXIT CODES
#   0   Every scanned path classified ok, allowlisted, or binary-skip.
#   1   One or more cjk-hit findings.
#   2   Usage error, python3 missing, or internal error.
#
# ALLOWLIST SURFACES
#   1. Path-based: .specaffold/features/**/00-request.md — only the block
#      bounded by a "**Raw ask**:" prefix line and the following blank line
#      is permitted to contain CJK. Every other line in that file is scanned.
#
#   2. Inline marker: any file containing a line:
#        <!-- scaff-lint: allow-cjk reason="..." -->
#      suppresses CJK scanning for that entire file. The reason is mandatory.
#
# =============================================================================
set -u -o pipefail
# NOTE: -e is intentionally omitted; we accumulate findings across files
# rather than aborting on the first hit.

# ---------------------------------------------------------------------------
# Python 3 preflight — exit 2 if unavailable
# ---------------------------------------------------------------------------
command -v python3 >/dev/null 2>&1 || {
  echo "scaff-lint: python3 required but not found" >&2
  exit 2
}

# ---------------------------------------------------------------------------
# usage
# ---------------------------------------------------------------------------
usage() {
  sed -n '/^# USAGE/,/^# ===*/p' "$0" | sed 's/^# \{0,1\}//'
  exit 0
}

# ---------------------------------------------------------------------------
# run_scanner MODE [args...]
#   MODE = staged  → reads staged content via git show :FILE
#   MODE = paths   → reads on-disk files directly
#   args for staged: none (reads git diff output internally)
#   args for paths: one or more file paths
#
# Invokes the embedded Python 3 scanner via argv-form (no shell concatenation
# of untrusted input). The scanner emits classifier lines to stdout and a
# summary to stderr; exits 0 (clean) or 1 (cjk-hit).
# ---------------------------------------------------------------------------
run_scanner() {
  local mode="$1"
  shift
  # All remaining args are passed as argv to python3; no shell word-splitting
  # of untrusted path data occurs here — each path is its own argv element.
  python3 - "$mode" "$@" <<'PYEOF'
# =============================================================================
# scaff-lint — Python 3 scanner (embedded heredoc)
# Pure classifier: no mutation, no filesystem writes.
# =============================================================================
import sys
import os

# ---------------------------------------------------------------------------
# repo_root — resolved once; used as boundary for path traversal check
# Falls back to CWD when not inside a git repo (edge-case environments).
# ---------------------------------------------------------------------------
import subprocess

def _resolve_repo_root():
    try:
        proc = subprocess.run(
            ['git', 'rev-parse', '--show-toplevel'],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
        if proc.returncode == 0:
            return os.path.realpath(proc.stdout.decode('utf-8', errors='replace').strip())
    except OSError:
        pass
    return os.path.realpath(os.getcwd())

_REPO_ROOT = _resolve_repo_root()
_REPO_ROOT_PREFIX = _REPO_ROOT + os.sep   # e.g. /path/to/repo/ — avoids /foo matching /foobar

# ---------------------------------------------------------------------------
# D6 Unicode ranges (verbatim from 04-tech.md §3 D6)
# ---------------------------------------------------------------------------
CJK_RANGES = (
    (0x3400, 0x4DBF), (0x4E00, 0x9FFF), (0x3000, 0x303F),
    (0x3040, 0x309F), (0x30A0, 0x30FF), (0xAC00, 0xD7AF),
    (0xF900, 0xFAFF), (0xFF00, 0xFFEF),
)

def is_cjk(cp):
    return any(lo <= cp <= hi for (lo, hi) in CJK_RANGES)

# ---------------------------------------------------------------------------
# Inline marker allowlist — suppress CJK scanning for the whole file
# Marker literal: <!-- scaff-lint: allow-cjk reason="..." -->
# ---------------------------------------------------------------------------
INLINE_MARKER = '<!-- scaff-lint: allow-cjk reason='

def has_inline_allowlist(lines):
    for line in lines:
        if INLINE_MARKER in line:
            return True
    return False

# ---------------------------------------------------------------------------
# Path-based allowlist for 00-request.md files
# The block starting with a "**Raw ask**:" prefix line, up to (but not
# including) the following blank line, is permitted to contain CJK.
# ---------------------------------------------------------------------------
def build_allowed_line_set(path, lines):
    """Return a set of 1-based line numbers that are allowlisted by the
    path-based rule. Only applies to paths matching */00-request.md."""
    basename = os.path.basename(path)
    if basename != '00-request.md':
        return set()
    allowed = set()
    in_block = False
    for i, line in enumerate(lines, 1):
        stripped = line.rstrip('\n')
        if stripped.startswith('**Raw ask**:'):
            in_block = True
            allowed.add(i)
            continue
        if in_block:
            if stripped == '':
                in_block = False
            else:
                allowed.add(i)
    return allowed

# ---------------------------------------------------------------------------
# Binary detection — probe the first 8 KB for a NUL byte
# ---------------------------------------------------------------------------
def is_binary(content_bytes):
    return b'\x00' in content_bytes[:8192]

# ---------------------------------------------------------------------------
# classify_content — core scanner
# Returns (verdict, findings)
#   verdict: 'ok' | 'cjk-hit' | 'allowlisted'
#   findings: list of (line_no, col_no, codepoint_hex) tuples for cjk-hit
# ---------------------------------------------------------------------------
def classify_content(path, content_bytes):
    # Inline marker check — file gets allowlisted before decoding line-by-line
    try:
        raw_text = content_bytes.decode('utf-8', errors='replace')
    except Exception:
        raw_text = content_bytes.decode('latin-1', errors='replace')

    lines = raw_text.splitlines(keepends=True)

    if has_inline_allowlist(lines):
        return ('allowlisted', 'inline-marker', [])

    allowed_lines = build_allowed_line_set(path, lines)
    findings = []

    for line_no, line in enumerate(lines, 1):
        if line_no in allowed_lines:
            continue
        for col_no, ch in enumerate(line, 1):
            cp = ord(ch)
            if is_cjk(cp):
                findings.append((line_no, col_no, cp))

    if findings:
        return ('cjk-hit', None, findings)
    return ('ok', None, [])

# ---------------------------------------------------------------------------
# emit_result — write classifier line to stdout
# ---------------------------------------------------------------------------
def emit_result(path, verdict, reason, findings):
    if verdict == 'ok':
        print('ok:' + path, flush=True)
    elif verdict == 'allowlisted':
        print('allowlisted:' + path + ':' + reason, flush=True)
    elif verdict == 'binary-skip':
        print('binary-skip:' + path, flush=True)
    elif verdict == 'cjk-hit':
        for (line_no, col_no, cp) in findings:
            print(
                'cjk-hit:' + path + ':' + str(line_no) + ':' +
                str(col_no) + ':U+' + format(cp, '04X'),
                flush=True,
            )

# ---------------------------------------------------------------------------
# is_out_of_scope — paths we never scan
# ---------------------------------------------------------------------------
def is_out_of_scope(path):
    norm = path.replace('\\', '/')
    for prefix in ('.specaffold/archive/', '.git/', 'node_modules/'):
        if norm.startswith(prefix) or ('/' + prefix) in ('/' + norm):
            return True
    return False

# ---------------------------------------------------------------------------
# scan_one_path — read from disk; return exit-contribution (0, 1, or 2)
#   0 = clean / out-of-scope / binary-skip
#   1 = cjk-hit
#   2 = boundary rejection (caller must propagate exit 2)
# ---------------------------------------------------------------------------
def scan_one_path(path):
    if is_out_of_scope(path):
        return 0
    # Boundary check: resolve symlinks and assert the path sits under repo root.
    # os.path.realpath resolves symlink chains, so a symlink pointing outside
    # the repo is caught here even when the link itself lives inside the repo.
    resolved = os.path.realpath(os.path.abspath(path))
    if resolved != _REPO_ROOT and not resolved.startswith(_REPO_ROOT_PREFIX):
        print('error: path outside repo root: ' + path, file=sys.stderr)
        return 2
    try:
        with open(resolved, 'rb') as fh:
            content_bytes = fh.read()
    except OSError as exc:
        print('scaff-lint: cannot read ' + path + ': ' + str(exc), file=sys.stderr)
        return 1

    if is_binary(content_bytes):
        emit_result(path, 'binary-skip', None, [])
        return 0

    verdict, reason, findings = classify_content(path, content_bytes)
    emit_result(path, verdict, reason, findings)
    return 1 if verdict == 'cjk-hit' else 0

# ---------------------------------------------------------------------------
# scan_staged — batch-reads all staged blobs via a single git cat-file --batch
# process; avoids per-file git show forks (performance: O(1) forks vs O(n)).
# ---------------------------------------------------------------------------
def scan_staged():
    # One fork: fetch the list of staged paths using NUL-separated output so
    # filenames with spaces or special characters parse safely.
    try:
        diff_proc = subprocess.run(
            ['git', 'diff', '--cached', '--name-only', '-z'],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
    except OSError as exc:
        print('scaff-lint: git invocation failed: ' + str(exc), file=sys.stderr)
        sys.exit(2)

    if diff_proc.returncode != 0:
        msg = diff_proc.stderr.decode('utf-8', errors='replace').strip()
        print('scaff-lint: git diff failed: ' + msg, file=sys.stderr)
        sys.exit(2)

    # -z output: NUL-separated paths; filter empty tokens and out-of-scope paths.
    all_paths = [p for p in diff_proc.stdout.split(b'\0') if p]
    paths = [p for p in all_paths if not is_out_of_scope(p.decode('utf-8', errors='replace'))]

    hit_count = 0
    ok_count = 0

    if not paths:
        print('scaff-lint: 0 path(s) scanned; all clean', file=sys.stderr)
        sys.exit(0)

    # One fork: open a git cat-file --batch process that accepts blob-object
    # references on stdin and streams blob contents on stdout — one round-trip
    # per path, no extra subprocess per file.
    try:
        cat = subprocess.Popen(
            ['git', 'cat-file', '--batch'],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
        )
    except OSError as exc:
        print('scaff-lint: git cat-file failed: ' + str(exc), file=sys.stderr)
        sys.exit(2)

    # Send all requests at once then close stdin so git flushes its output.
    req = b''.join(b':' + p + b'\n' for p in paths)
    cat.stdin.write(req)
    cat.stdin.close()

    # Read one response header per requested path, in order.
    for path_bytes in paths:
        path_str = path_bytes.decode('utf-8', errors='replace')
        header = cat.stdout.readline()
        if not header:
            break
        # Header form: "<sha> blob <size>\n"  or  "<ref> missing\n"
        header_stripped = header.rstrip(b'\n')
        if header_stripped.endswith(b'missing'):
            # File deleted or not a blob in the index — skip silently.
            continue
        try:
            _sha, _obj_type, size_str = header_stripped.split(b' ')
            size = int(size_str)
        except ValueError:
            # Unexpected header shape — skip this blob.
            continue

        content_bytes = cat.stdout.read(size)
        cat.stdout.read(1)  # consume the trailing newline that follows each blob

        if is_binary(content_bytes):
            emit_result(path_str, 'binary-skip', None, [])
            ok_count += 1
            continue

        verdict, reason, findings = classify_content(path_str, content_bytes)
        emit_result(path_str, verdict, reason, findings)
        if verdict == 'cjk-hit':
            hit_count += 1
        else:
            ok_count += 1

    cat.stdout.close()
    cat.wait()

    if hit_count > 0:
        print('scaff-lint: ' + str(hit_count) + ' cjk-hit finding(s); '
              + str(ok_count) + ' path(s) clean', file=sys.stderr)
        sys.exit(1)
    else:
        print('scaff-lint: ' + str(ok_count) + ' path(s) scanned; all clean',
              file=sys.stderr)
        sys.exit(0)

# ---------------------------------------------------------------------------
# scan_paths — on-disk paths supplied as argv
# ---------------------------------------------------------------------------
def scan_paths(paths):
    hit_count = 0
    ok_count = 0
    boundary_rejected = 0
    for path in paths:
        contrib = scan_one_path(path)
        if contrib == 2:
            boundary_rejected += 1
        elif contrib == 1:
            hit_count += 1
        else:
            ok_count += 1

    if boundary_rejected > 0:
        # Boundary rejection is an internal/usage error — exit 2 regardless of cjk findings.
        sys.exit(2)
    if hit_count > 0:
        print('scaff-lint: ' + str(hit_count) + ' cjk-hit finding(s); '
              + str(ok_count) + ' path(s) clean', file=sys.stderr)
        sys.exit(1)
    else:
        print('scaff-lint: ' + str(ok_count) + ' path(s) scanned; all clean',
              file=sys.stderr)
        sys.exit(0)

# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------
def main():
    args = sys.argv[1:]  # argv[0] is the mode injected by the bash shim

    if not args:
        print('scaff-lint: missing subcommand', file=sys.stderr)
        sys.exit(2)

    mode = args[0]

    if mode == 'staged':
        scan_staged()
    elif mode == 'paths':
        paths = args[1:]
        if not paths:
            print('scaff-lint: scan-paths requires at least one path', file=sys.stderr)
            sys.exit(2)
        scan_paths(paths)
    else:
        print('scaff-lint: unknown mode: ' + mode, file=sys.stderr)
        sys.exit(2)

main()
PYEOF
}

# ---------------------------------------------------------------------------
# Argument dispatch
# ---------------------------------------------------------------------------
case "${1:-}" in
  --help|-h|"")
    usage
    ;;
  scan-staged)
    run_scanner "staged"
    exit $?
    ;;
  scan-paths)
    shift
    if [ $# -eq 0 ]; then
      echo "scaff-lint: scan-paths requires at least one path" >&2
      exit 2
    fi
    run_scanner "paths" "$@"
    exit $?
    ;;
  *)
    echo "scaff-lint: unknown subcommand: ${1}" >&2
    echo "Run 'bin/scaff-lint --help' for usage." >&2
    exit 2
    ;;
esac
