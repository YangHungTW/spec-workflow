#!/usr/bin/env bash
# =============================================================================
# specflow-seed — seed per-project .claude/ scaffolding from the source repo
# =============================================================================
#
# USAGE
#   bin/specflow-seed <subcommand> [options]
#   bin/specflow-seed --help
#
# SUBCOMMANDS
#   init      Copy the managed .claude/ subtree into a consumer project.
#             Safe to re-run (idempotent once implemented in Wave 1+).
#
#   update    Pull upstream changes from the source repo into the consumer.
#             Respects the classify-before-mutate contract; skips user-modified
#             files (no force flag in v1; skip-and-report is the conflict policy).
#
#   migrate   Migrate this repo (the source) to consume itself, staging the
#             copy as a structural-only dry-run first.
#
# OPTIONS
#   --dry-run         Compute the full plan; zero mutations; exit 0 unless
#                     planning fails.
#   --from <path>     Explicit path to the source repo root (default: cwd or
#                     git rev-parse --show-toplevel).
#   --to <ref>        Consumer project root path (init / update only).
#   --ref <ref>       Pin copy to a specific git ref from the source repo.
#   --help, -h        Print this message and exit 0.
#
# EXIT CODES
#   0   All files converged to desired state (or dry-run produced a plan).
#   1   At least one file was skipped or a mutation failed; tool reports all.
#   2   Usage error, python3 missing, unresolvable source, or corrupt manifest.
#
# CONFLICT HANDLING (skip-and-report; no force flag in v1)
#   Conflicts are reported and skipped; the user resolves them manually.
#
# =============================================================================
set -u -o pipefail

# ---------------------------------------------------------------------------
# Globals
# ---------------------------------------------------------------------------
DRY_RUN=0
SRC=""
TO_REF=""
AT_REF=""

# MAX_CODE: tracks the highest exit code seen so far.
# 0 = fully converged; 1 = conflict or mutation failure; 2 = die()
MAX_CODE=0

# Cached uname for sha256 dispatch — populated once on first call to sha256_of
_UNAME_S=""

# ---------------------------------------------------------------------------
# die <msg> — print msg to stderr and exit 2
# ---------------------------------------------------------------------------
die() {
  local msg="$1"
  echo "specflow-seed: $msg" >&2
  exit 2
}

# ---------------------------------------------------------------------------
# resolve_path <p> — BSD-safe portable path resolution (no GNU readlink flags)
# Iteratively resolves symlinks; caps at 40 hops to detect cycles.
# ---------------------------------------------------------------------------
resolve_path() {
  local p="$1" i=0
  case "$p" in
    /*) ;;
    *)  p="$(pwd -P)/$p" ;;
  esac
  while [ "$i" -lt 40 ]; do
    local d b
    d=$(cd "$(dirname "$p")" 2>/dev/null && pwd -P) || die "resolve_path: cannot cd into '$(dirname "$p")'"
    b=$(basename "$p")
    p="$d/$b"
    if [ -L "$p" ]; then
      local t
      t=$(readlink "$p")
      case "$t" in
        /*) p="$t" ;;
        *)  p="$d/$t" ;;
      esac
      i=$((i + 1))
    else
      printf '%s\n' "$p"
      return 0
    fi
  done
  die "symlink cycle at '$1'"
}

# ---------------------------------------------------------------------------
# repo_root — resolves the source repo root.
# Prefers git rev-parse --show-toplevel; falls back to pwd -P.
# Result stored in REPO_ROOT (cached).
# ---------------------------------------------------------------------------
REPO_ROOT=""
repo_root() {
  if [ -n "$REPO_ROOT" ]; then
    printf '%s\n' "$REPO_ROOT"
    return 0
  fi
  local root
  root=$(git rev-parse --show-toplevel 2>/dev/null) || root=$(pwd -P)
  REPO_ROOT="$root"
  printf '%s\n' "$REPO_ROOT"
}

# ---------------------------------------------------------------------------
# usage — print the header comment block and exit 0
# ---------------------------------------------------------------------------
usage() {
  sed -n '/^# USAGE/,/^# ===*/p' "$0" | sed 's/^# \{0,1\}//'
  exit 0
}

# ---------------------------------------------------------------------------
# emit_summary — wired from cmd_init/update/migrate after the classifier and
# dispatcher land; exit-code shape is stable across waves.
# ---------------------------------------------------------------------------
emit_summary() {
  echo "summary: created=0 already=0 replaced=0 skipped=0 (exit $MAX_CODE)"
}

# ---------------------------------------------------------------------------
# sha256_of <path>
# Dispatch by uname -s: Darwin/*BSD → shasum -a 256; Linux/* → sha256sum.
# Python 3 hashlib fallback if neither binary is present.
# Caches uname result in _UNAME_S to avoid repeated forks (performance rule).
# ---------------------------------------------------------------------------
sha256_of() {
  local path="$1"
  if [ -z "$_UNAME_S" ]; then
    _UNAME_S="$(uname -s 2>/dev/null)"
  fi
  case "$_UNAME_S" in
    Darwin|FreeBSD|OpenBSD|NetBSD)
      if command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$path" | awk '{print $1}'
        return
      fi
      ;;
    *)
      if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$path" | awk '{print $1}'
        return
      fi
      ;;
  esac
  # Python 3 fallback — allowed on install-time paths (bash-32-portability rule)
  python3 -c 'import hashlib,sys; print(hashlib.sha256(open(sys.argv[1],"rb").read()).hexdigest())' "$path"
}

# ---------------------------------------------------------------------------
# manifest_ref_sniff <path>
# Bash-only defensive ref reader — no Python 3.
# Used when callers need only the ref string, not the full file map.
# Exact awk form from D3 tradeoffs in 04-tech.md.
# TODO(W2-W4): used by cmd_update as defensive fallback when full manifest
# parse is overkill (only the ref string is needed for a quick staleness check).
# ---------------------------------------------------------------------------
manifest_ref_sniff() {
  awk -F'"' '/"specflow_ref"/ { print $4; exit }' "$1"
}

# ---------------------------------------------------------------------------
# manifest_read <path>
# Python 3 heredoc. Validates schema v1; emits relpath<TAB>sha256 rows on stdout.
# Exits 2 with "manifest: corrupt" on stderr for any schema or parse failure.
# TODO(W3): consumed by cmd_update's classifier baseline lookup — maps each
# relpath to its baseline sha256 so classify_copy_target can distinguish
# drifted-ours from user-modified.
# ---------------------------------------------------------------------------
manifest_read() {
  local mpath="$1"
  python3 - "$mpath" <<'PYEOF'
import sys, json

path = sys.argv[1]
try:
    with open(path, 'r') as f:
        data = json.load(f)
except Exception as e:
    print("manifest: corrupt", file=sys.stderr)
    sys.exit(2)

if data.get("schema_version") != 1:
    print("manifest: corrupt", file=sys.stderr)
    sys.exit(2)
if not isinstance(data.get("specflow_ref"), str) or not data["specflow_ref"]:
    print("manifest: corrupt", file=sys.stderr)
    sys.exit(2)
if not isinstance(data.get("files"), dict):
    print("manifest: corrupt", file=sys.stderr)
    sys.exit(2)

# Boundary validation — reject traversal and absolute relpaths at the first
# point of entry into the call tree so all downstream consumers can trust inputs.
for relpath, sha in data["files"].items():
    if not relpath:
        print("manifest: corrupt", file=sys.stderr)
        sys.exit(2)
    if relpath.startswith("/"):
        print("manifest: corrupt", file=sys.stderr)
        sys.exit(2)
    parts = relpath.replace("\\", "/").split("/")
    if ".." in parts:
        print("manifest: corrupt", file=sys.stderr)
        sys.exit(2)
    print("{}\t{}".format(relpath, sha))
PYEOF
}

# ---------------------------------------------------------------------------
# manifest_write <path> <ref> <source_remote> <applied_at>
# Reads relpath<TAB>sha256 rows from stdin; builds D3 schema v1 JSON;
# writes atomically to <path> via .tmp + os.replace (D11 discipline).
# Caller must write .bak before invoking this when overwriting an existing
# manifest (backup discipline applies at cmd_update / cmd_migrate call-sites).
#
# Implementation note: bash heredoc (<<'PYEOF') and piped stdin cannot both
# feed into a single python3 invocation — heredoc wins as the script source.
# We capture stdin to a temp file before invoking python3 so the TSV data is
# available independently of the heredoc channel.
# TODO(W2,W3,W4): called after each successful init/update/migrate run to
# record the new specflow_ref and file checksums in the consumer's manifest.
# ---------------------------------------------------------------------------
manifest_write() {
  local mpath="$1" ref="$2" source_remote="$3" applied_at="$4"
  local tsv_tmp
  tsv_tmp=$(mktemp)
  cat > "$tsv_tmp"
  python3 - "$mpath" "$ref" "$source_remote" "$applied_at" "$tsv_tmp" <<'PYEOF'
import sys, json, os

path          = sys.argv[1]
ref           = sys.argv[2]
source_remote = sys.argv[3]
applied_at    = sys.argv[4]
tsv_file      = sys.argv[5]

files = {}
with open(tsv_file, 'r') as fh:
    for line in fh:
        line = line.rstrip("\n")
        if not line:
            continue
        parts = line.split("\t", 1)
        if len(parts) == 2:
            files[parts[0]] = parts[1]

data = {
    "schema_version": 1,
    "specflow_ref": ref,
    "source_remote": source_remote,
    "applied_at": applied_at,
    "files": files,
}

tmp = path + ".tmp"
os.makedirs(os.path.dirname(os.path.abspath(path)), exist_ok=True)
with open(tmp, "w") as f:
    json.dump(data, f, indent=2, sort_keys=False)
    f.write("\n")
os.replace(tmp, path)
PYEOF
  local rc=$?
  rm -f "$tsv_tmp"
  return $rc
}

# ---------------------------------------------------------------------------
# classify_copy_target <consumer_root> <relpath> <expected_sha> <baseline_sha>
#
# Pure function; emits exactly one of five enum values on stdout:
#   missing | ok | drifted-ours | user-modified | real-file-conflict
#
# Note on the 5-vs-6 state question: The D4 pseudocode (04-tech.md §3) has
# exactly 5 return paths. The dispatcher table lists a 6th state "foreign"
# which is emitted by the copy-phase dispatcher when a path falls outside the
# managed set — not by this classifier. This function implements the D4
# pseudocode branch-for-branch; "foreign" is NOT a return value here.
#
# <baseline_sha> == "" represents "absent from manifest" (pseudocode's None).
# No side effects. No mutations.
# ---------------------------------------------------------------------------
classify_copy_target() {
  local consumer_root="$1" relpath="$2" expected_sha="$3" baseline_sha="$4"

  # Defense-in-depth: reject traversal inputs even though manifest_read already
  # validates at the boundary — belt-and-suspenders guards the classifier if ever
  # called directly (e.g., from a future probe or unit test with raw inputs).
  case "$relpath" in
    ..*|*/..*|*/..|/*)
      die "classify_copy_target: traversal rejected" ;;
  esac

  local dst="${consumer_root}/${relpath}"

  # Branch 1: dst does not exist (neither as file nor as symlink)
  if [ ! -e "$dst" ] && [ ! -L "$dst" ]; then
    echo "missing"
    return
  fi

  # Branch 2: dst is a symlink — we never create symlinks (R1)
  if [ -L "$dst" ]; then
    echo "real-file-conflict"
    return
  fi

  # Branch 3: dst is a directory — file expected here
  if [ -d "$dst" ]; then
    echo "real-file-conflict"
    return
  fi

  # Branch 4: dst is not a regular file (fifo, device, etc.)
  if [ ! -f "$dst" ]; then
    echo "real-file-conflict"
    return
  fi

  # Branch 5: dst is a regular file — compare hashes
  local actual_sha
  actual_sha=$(sha256_of "$dst")

  if [ "$actual_sha" = "$expected_sha" ]; then
    echo "ok"
    return
  fi

  # baseline_sha == "" means absent from manifest (pseudocode None branch)
  if [ -z "$baseline_sha" ]; then
    # File is new in the new ref but destination already has content —
    # the user must have created it manually; cannot be ours.
    echo "user-modified"
    return
  fi

  if [ "$actual_sha" = "$baseline_sha" ]; then
    echo "drifted-ours"
    return
  fi

  echo "user-modified"
}

# ---------------------------------------------------------------------------
# plan_copy <src_root> <mode>
# Enumerates managed relpaths from the source tree.
# mode=init|migrate: includes static subtrees + team-memory skeleton.
# mode=update:       static subtrees only (update never touches team-memory).
# Emits newline-separated relpaths on stdout.
# ---------------------------------------------------------------------------
plan_copy() {
  local src_root="$1" mode="$2"

  local prefix
  for prefix in \
    ".claude/agents/specflow" \
    ".claude/commands/specflow" \
    ".claude/hooks" \
    ".claude/rules" \
    ".spec-workflow/features/_template"
  do
    if [ -d "${src_root}/${prefix}" ]; then
      find "${src_root}/${prefix}" -type f | while IFS= read -r fpath; do
        local rel="${fpath#${src_root}/}"
        printf '%s\n' "$rel"
      done
    fi
  done

  # Team-memory skeleton — only for init or migrate modes
  case "$mode" in
    init|migrate)
      # Enumerate role dirs (non-shared subdirs of .claude/team-memory)
      local tm_root="${src_root}/.claude/team-memory"
      if [ -d "$tm_root" ]; then
        find "$tm_root" -maxdepth 1 -mindepth 1 -type d | sort | while IFS= read -r role_dir; do
          local role_name
          role_name=$(basename "$role_dir")
          if [ "$role_name" != "shared" ]; then
            # Synthesized: one index.md per role dir (empty-skeleton per R4)
            printf '.claude/team-memory/%s/index.md\n' "$role_name"
          fi
        done
        # shared dir always gets both README.md and index.md
        printf '.claude/team-memory/shared/README.md\n'
        printf '.claude/team-memory/shared/index.md\n'
      fi
      ;;
  esac
}

# ---------------------------------------------------------------------------
# write_atomic <dst>
# Python 3 heredoc. Reads bytes from stdin; writes to <dst>.tmp; os.replace.
# Ensures parent directory exists. No partial-write window (D11 discipline).
#
# Same stdin/heredoc conflict as manifest_write: capture bytes to temp file
# first so the piped data and the Python heredoc don't compete for stdin.
# TODO(W2-W4): called from every D4 dispatcher arm that produces filesystem
# writes (missing → create, drifted-ours → replace after .bak).
# ---------------------------------------------------------------------------
write_atomic() {
  local dst="$1"
  local data_tmp
  data_tmp=$(mktemp)
  cat > "$data_tmp"
  python3 - "$dst" "$data_tmp" <<'PYEOF'
import sys, os

dst      = sys.argv[1]
src_file = sys.argv[2]
with open(src_file, "rb") as f:
    data = f.read()
tmp = dst + ".tmp"
os.makedirs(os.path.dirname(os.path.abspath(dst)), exist_ok=True)
with open(tmp, "wb") as f:
    f.write(data)
os.replace(tmp, dst)
PYEOF
  local rc=$?
  rm -f "$data_tmp"
  return $rc
}

# ---------------------------------------------------------------------------
# Flag parser — no GNU getopt (portability)
# ---------------------------------------------------------------------------
parse_flags() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      --from)
        [ "$#" -ge 2 ] || die "flag --from requires an argument"
        SRC="$2"
        shift 2
        ;;
      --to)
        [ "$#" -ge 2 ] || die "flag --to requires an argument"
        TO_REF="$2"
        shift 2
        ;;
      --ref)
        [ "$#" -ge 2 ] || die "flag --ref requires an argument"
        AT_REF="$2"
        shift 2
        ;;
      --help|-h)
        usage
        ;;
      --)
        shift
        break
        ;;
      -*)
        die "unknown flag: $1"
        ;;
      *)
        break
        ;;
    esac
  done
}

# ---------------------------------------------------------------------------
# Preflight — python3 required for manifest write (D4 tradeoff).
# Called by each subcommand AFTER flag parsing; NOT called for --help / usage.
# ---------------------------------------------------------------------------
preflight() {
  command -v python3 >/dev/null || die "python3 required"
}

# ---------------------------------------------------------------------------
# Subcommand stubs (Wave 0 — no filesystem mutation)
# ---------------------------------------------------------------------------
cmd_init() {
  echo "init: not-yet-implemented"
  exit 0
}

cmd_update() {
  echo "update: not-yet-implemented"
  exit 0
}

cmd_migrate() {
  echo "migrate: not-yet-implemented"
  exit 0
}

# ---------------------------------------------------------------------------
# cmd_probe — hidden __probe subcommand for Wave 1 TDD harness.
# Not listed in usage(). Exposes library functions for isolated testing.
#
# Verbs:
#   classify <consumer_root> <relpath> <expected_sha> <baseline_sha>
#   manifest-roundtrip <path>
#   plan <src_root> <mode>
# ---------------------------------------------------------------------------
cmd_probe() {
  local verb="${1:-}"
  case "$verb" in
    classify)
      [ "$#" -eq 5 ] || die "__probe classify requires 4 arguments: <consumer_root> <relpath> <expected_sha> <baseline_sha>"
      classify_copy_target "$2" "$3" "$4" "$5"
      ;;
    manifest-roundtrip)
      [ "$#" -eq 2 ] || die "__probe manifest-roundtrip requires 1 argument: <path>"
      local mpath="$2"
      local sibling="${mpath%.manifest}.roundtrip.tmp"
      python3 - "$mpath" "$sibling" <<'PYEOF'
import sys, json, os

src  = sys.argv[1]
dst  = sys.argv[2]

with open(src, 'r') as f:
    data = json.load(f)

if data.get("schema_version") != 1:
    print("manifest: corrupt", file=sys.stderr)
    sys.exit(2)
if not isinstance(data.get("specflow_ref"), str) or not data["specflow_ref"]:
    print("manifest: corrupt", file=sys.stderr)
    sys.exit(2)
if not isinstance(data.get("files"), dict):
    print("manifest: corrupt", file=sys.stderr)
    sys.exit(2)

# Boundary validation — same traversal check as manifest_read
for relpath in data["files"]:
    if not relpath:
        print("manifest: corrupt", file=sys.stderr)
        sys.exit(2)
    if relpath.startswith("/"):
        print("manifest: corrupt", file=sys.stderr)
        sys.exit(2)
    if ".." in relpath.replace("\\", "/").split("/"):
        print("manifest: corrupt", file=sys.stderr)
        sys.exit(2)

# Re-assemble with same field order as manifest_write
out = {
    "schema_version": 1,
    "specflow_ref": data["specflow_ref"],
    "source_remote": data.get("source_remote", ""),
    "applied_at": data.get("applied_at", ""),
    "files": data["files"],
}

tmp = dst + ".tmp"
os.makedirs(os.path.dirname(os.path.abspath(dst)), exist_ok=True)
with open(tmp, "w") as f:
    json.dump(out, f, indent=2, sort_keys=False)
    f.write("\n")
os.replace(tmp, dst)
PYEOF
      local py_rc=$?
      if [ "$py_rc" -ne 0 ]; then
        rm -f "$sibling"
        exit "$py_rc"
      fi
      if cmp -s "$mpath" "$sibling"; then
        rm -f "$sibling"
        exit 0
      else
        echo "manifest-roundtrip: byte mismatch" >&2
        rm -f "$sibling"
        exit 1
      fi
      ;;
    plan)
      [ "$#" -eq 3 ] || die "__probe plan requires 2 arguments: <src_root> <mode>"
      plan_copy "$2" "$3"
      ;;
    *)
      die "__probe: unknown verb '${verb}' (classify|manifest-roundtrip|plan)"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Main dispatcher
# ---------------------------------------------------------------------------
_cmd="${1:-}"

case "$_cmd" in
  -h|--help|"")
    usage
    ;;
  init|update|migrate|__probe)
    shift
    parse_flags "$@"
    preflight
    case "$_cmd" in
      init)    cmd_init ;;
      update)  cmd_update ;;
      migrate) cmd_migrate ;;
      __probe) cmd_probe "$@" ;;
    esac
    ;;
  --dry-run|--from|--to|--ref)
    # Flags before subcommand: parse all flags first, then re-dispatch
    parse_flags "$@"
    die "subcommand required (init, update, migrate)"
    ;;
  *)
    die "unknown subcommand: $_cmd"
    ;;
esac
