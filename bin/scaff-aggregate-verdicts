#!/usr/bin/env bash
# =============================================================================
# scaff-aggregate-verdicts — parameterised verdict aggregator CLI
# =============================================================================
#
# USAGE
#   bin/scaff-aggregate-verdicts <axis> [<axis>...] --dir <verdict-dir>
#
# POSITIONAL
#   <axis>...   One or more axis names (e.g. security performance style).
#               The aggregator reads all *.txt files in <verdict-dir> and
#               applies the BLOCK > NITS > PASS max-reduce classifier.
#               At least one axis name is required.
#
# OPTION
#   --dir <path>   Directory containing per-axis verdict files (<name>.txt).
#                  Required. Must exist.
#
# OUTPUT (stdout)
#   Line 1:  PASS | NITS | BLOCK   — aggregated verdict
#   Line 2:  suggest-audited-upgrade: <axis-name>
#            Emitted ONLY when any verdict file contains both:
#              axis: security
#              severity: must
#            (tech §4.3 / R14 auto-upgrade signal)
#
# EXIT CODES
#   0   Classification complete (PASS, NITS, or BLOCK)
#   2   Argument error (no axis-set, missing --dir, dir does not exist)
#
# ERROR POSTURE
#   A verdict file with a missing "## Reviewer verdict" or "## Validate verdict" header, a missing
#   "verdict:" key, or a verdict value outside {PASS, NITS, BLOCK} is
#   treated as BLOCK (fail-loud per tech §4.1).
#
# BASH 3.2 / BSD PORTABLE
#   No readlink -f, realpath, jq, mapfile, [[ =~ ]].
# =============================================================================

set -u -o pipefail

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

AXIS_SET=""
VERDICT_DIR=""

# Walk argv: collect positional axis names until we hit --dir <path>.
# Any unrecognised flag emits a usage error.
i=0
for arg in "$@"; do
  i=$((i + 1))
  if [ "$arg" = "--dir" ]; then
    # The next argument is the directory path.
    # We handle this in the second pass below.
    break
  fi
  case "$arg" in
    --*)
      printf 'scaff-aggregate-verdicts: unknown option: %s\n' "$arg" >&2
      printf 'Usage: scaff-aggregate-verdicts <axis>... --dir <verdict-dir>\n' >&2
      exit 2
      ;;
    *)
      # Positional axis name.
      AXIS_SET="$AXIS_SET $arg"
      ;;
  esac
done

# Second pass: extract the --dir value.
# We scan all args for the "--dir" flag and grab the following token.
FOUND_DIR_FLAG=0
PREV_WAS_DIR=0
for arg in "$@"; do
  if [ "$PREV_WAS_DIR" = "1" ]; then
    VERDICT_DIR="$arg"
    FOUND_DIR_FLAG=1
    PREV_WAS_DIR=0
    continue
  fi
  if [ "$arg" = "--dir" ]; then
    PREV_WAS_DIR=1
  fi
done

# Validate: at least one axis name required.
# AXIS_SET contains a leading space; strip it for the empty check.
AXIS_SET="${AXIS_SET# }"
if [ -z "$AXIS_SET" ]; then
  printf 'scaff-aggregate-verdicts: axis-set is required (at least one axis name)\n' >&2
  printf 'Usage: scaff-aggregate-verdicts <axis>... --dir <verdict-dir>\n' >&2
  exit 2
fi

# Validate: --dir flag must have been provided.
if [ "$FOUND_DIR_FLAG" = "0" ]; then
  printf 'scaff-aggregate-verdicts: --dir <verdict-dir> is required\n' >&2
  printf 'Usage: scaff-aggregate-verdicts <axis>... --dir <verdict-dir>\n' >&2
  exit 2
fi

# Validate: verdict directory must exist.
if [ ! -d "$VERDICT_DIR" ]; then
  printf 'scaff-aggregate-verdicts: verdict dir does not exist: %s\n' "$VERDICT_DIR" >&2
  exit 2
fi

# ---------------------------------------------------------------------------
# Classification pass (pure — no mutation)
# ---------------------------------------------------------------------------
#
# State machine across all *.txt files in VERDICT_DIR:
#   AGG_STATE  : PASS | NITS | BLOCK  (max-reduce)
#   SECURITY_MUST : 0 | 1             (set when axis=security AND severity: must)
#
# Malformed footer (no ## Reviewer verdict / ## Validate verdict header, no verdict: line, or
# verdict value not in {PASS, NITS, BLOCK}) → treat as BLOCK (fail-loud).

AGG_STATE="PASS"
SECURITY_MUST=0

# Iterate over all verdict files in the directory.
for vfile in "$VERDICT_DIR"/*.txt; do
  # If the glob matched nothing, $vfile contains the literal glob string.
  # Skip non-existent files produced by an empty directory.
  [ -f "$vfile" ] || continue

  IN_VERDICT=0
  FOUND_HEADER=0
  VERDICT_VALUE=""
  FILE_AXIS=""
  HAS_SECURITY_MUST=0

  while IFS= read -r line; do
    if [ "$line" = "## Reviewer verdict" ] || [ "$line" = "## Validate verdict" ]; then
      IN_VERDICT=1
      FOUND_HEADER=1
      continue
    fi

    if [ "$IN_VERDICT" = "1" ]; then
      case "$line" in
        "axis: "*)
          FILE_AXIS="${line#axis: }"
          ;;
        "verdict: "*)
          VERDICT_VALUE="${line#verdict: }"
          ;;
        "  - severity: must"*)
          # Check if the current file's axis is security.
          if [ "$FILE_AXIS" = "security" ]; then
            HAS_SECURITY_MUST=1
          fi
          ;;
      esac
    fi
  done < "$vfile"

  # Malformed check — missing header or missing verdict: key.
  if [ "$FOUND_HEADER" = "0" ] || [ -z "$VERDICT_VALUE" ]; then
    printf 'scaff-aggregate-verdicts: malformed verdict footer in %s — treating as BLOCK\n' \
      "$vfile" >&2
    AGG_STATE="BLOCK"
    continue
  fi

  # Verdict value outside closed set → BLOCK.
  if [ "$VERDICT_VALUE" != "PASS" ] && \
     [ "$VERDICT_VALUE" != "NITS" ] && \
     [ "$VERDICT_VALUE" != "BLOCK" ]; then
    printf 'scaff-aggregate-verdicts: invalid verdict "%s" in %s — treating as BLOCK\n' \
      "$VERDICT_VALUE" "$vfile" >&2
    AGG_STATE="BLOCK"
    continue
  fi

  # Max-reduce: BLOCK > NITS > PASS.
  if [ "$VERDICT_VALUE" = "BLOCK" ]; then
    AGG_STATE="BLOCK"
  elif [ "$VERDICT_VALUE" = "NITS" ] && [ "$AGG_STATE" = "PASS" ]; then
    AGG_STATE="NITS"
  fi

  # Accumulate security-must signal.
  if [ "$HAS_SECURITY_MUST" = "1" ]; then
    SECURITY_MUST=1
  fi
done

# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------

printf '%s\n' "$AGG_STATE"

if [ "$SECURITY_MUST" = "1" ]; then
  printf 'suggest-audited-upgrade: security\n'
fi

exit 0
